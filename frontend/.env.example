# For local dev proxy (used by Vite dev server only)
VITE_API_PROXY_TARGET=http://localhost:8001

# If set, Predict tab will call Hugging Face directly instead of /api/predict
# Example: https://api-inference.huggingface.co/models/<username>/<model-repo>
VITE_HF_MODEL_URL=

# Optional if your HF model endpoint is private/rate-limited
VITE_HF_TOKEN=

# Frontend-only mode for static hosting (Netlify)
# true  => only show Predict tab
# false => show full dashboard tabs
VITE_FRONTEND_ONLY=true

# Optional: absolute backend URL (used in production builds for non-predict API calls)
# Example: https://your-backend.up.railway.app/api
VITE_API_BASE_URL=
